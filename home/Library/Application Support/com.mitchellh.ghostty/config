# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.
# font-family = Iosevka
# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

# Changed 2026-05-22: cmux 0.64.9 resolves the Ghostty theme only once, at
# process launch, and caches it for the life of the process. It does not
# re-resolve on config reload or when macOS appearance changes. With a
# light:/dark: split theme, every cmux launch is a coin flip on whatever macOS
# appearance is active at that instant -- a boot race that froze cmux's
# terminal panes on Gruvbox Light. Pinned to Gruvbox Dark unconditionally so
# every cmux launch resolves to dark regardless of timing. Standalone Ghostty
# no longer auto-switches to a light theme. To restore auto light/dark
# switching, swap the two theme lines below.
# theme = light:Gruvbox Light,dark:Gruvbox Dark
theme = Gruvbox Dark
minimum-contrast = 1.5
