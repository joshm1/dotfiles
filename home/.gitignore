# OSX       taken from: https://github.com/github/gitignore/blob/master/Global/OSX.gitignore
# ----------------------------------------------------------------------------------------------
.DS_Store
# Thumbnails
._*
# Files that might appear on external disk
.Spotlight-V100
.Trashes

# Windows   taken from: https://github.com/github/gitignore/blob/master/Global/Windows.gitignore
# ----------------------------------------------------------------------------------------------
# Windows image file caches
Thumbs.db

# Folder config file
Desktop.ini

# tmp files
.history/
tmp/

# local files
*.local
*.local.toml

# Tags      taken from: https://github.com/github/gitignore/blob/master/Global/Tags.gitignore
# ----------------------------------------------------------------------------------------------
# Ignore tags created by etags, ctags, gtags (GNU global) and cscope
TAGS
!TAGS/
tags
tags.lock
tags.temp
!tags/
gtags.files
GTAGS
GRTAGS
GPATH
cscope.files
cscope.out
cscope.in.out
cscope.po.out

# Vim       taken from: https://github.com/github/gitignore/blob/master/Global/vim.gitignore
# ----------------------------------------------------------------------------------------------
# Named-buffer swap files (e.g. .foo.swp). The companion anonymous-swap line
# ([._]s[a-w][a-z]) was removed because it matched any 4-char path component
# starting with .s — including .ssh — and caused parent-dir ignores that no
# local negation could rescue.
[._]*.s[a-w][a-z]
*.un~
Session.vim
.netrwhist
*~

# SASS
# ----------------------------------------------------------------------------------------------
.sass-cache

# IDE
# ----------------------------------------------------------------------------------------------
.idea/
.superset/

# dir-env
.envrc

# dotenv
.env*.local

.capistrano/
.agignore
*.hprof # jvm
routes.txt
.metals/

# CLAUDE settings.local.json
settings.local.json
